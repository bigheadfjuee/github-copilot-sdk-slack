# Environment Configuration
# .env.example - Copy to .env and fill in your values

# ===== Slack Configuration =====
# For Socket Mode
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# For HTTP Mode
SLACK_SIGNING_SECRET=your-signing-secret

# ===== Connection Mode =====
# Options: 'socket' or 'http'
CONNECTION_MODE=socket

# For HTTP mode
HTTP_PORT=3000
HTTP_PATH=/slack/events

# For HTTP Proxy mode (optional)
HTTP_PROXY_URL=
HTTP_PROXY_USERNAME=
HTTP_PROXY_PASSWORD=

# ===== Logging =====
LOG_LEVEL=debug

# ===== Application =====
NODE_ENV=development

# ===== GitHub Copilot =====
GITHUB_TOKEN=
COPILOT_SESSION_IDLE_MS=
COPILOT_TIMEOUT_MS=
